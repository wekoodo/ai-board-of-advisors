# User profile — generated during onboarding, local-only, never committed
_config/profile/personal.md
_config/profile/financial.md
_config/profile/businesses.md
_config/profile/investments.md
_config/profile/goals.md

# User meetings — local-only (the shipped example-* meetings are NOT excluded)
meetings/*/
!meetings/example-*/

# Pre-meeting document intake — folder + README tracked, dropped docs local-only
_inbox/*
!_inbox/README.md

# OS and editor files
.DS_Store
Thumbs.db
*.swp

# AI agent harness tooling — installed skill *content* is regenerable, like node_modules.
# skills-lock.json is the manifest that reproduces it on clone (`skills install`), so it IS tracked.
# Exception: maintaining-icm is authored here and tracked in-place until it's published to
# skills.sh; after that it becomes a normal skills-lock.json entry and this exception is removed.
.agents/*
!.agents/skills/
.agents/skills/*
!.agents/skills/maintaining-icm/
.claude/
.codex/

# Python bytecode (e.g. from running the maintaining-icm audit script)
__pycache__/
*.pyc

# Build / iteration scratch — authoring-only, not part of the distributable
tmp/
run-iterations.ps1
